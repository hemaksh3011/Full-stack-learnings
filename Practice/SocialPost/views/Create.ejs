<!DOCTYPE html>
<html>
<head>
  <title>Add Profile</title>
  <style>
    body {
      font-family: Arial;
      background: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .form-box {
      background: white;
      padding: 20px;
      border-radius: 10px;
      width: 300px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    h2 {
      text-align: center;
    }

    input, textarea {
      width: 100%;
      padding: 8px;
      margin: 8px 0;
      border-radius: 6px;
      border: 1px solid #ccc;
    }

    button {
      width: 100%;
      padding: 10px;
      background: black;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
    }

    button:hover {
      background: #333;
    }
  </style>
</head>

<body>

<div class="form-box">
  <h2>Create SocialPost</h2>

  <form method="post" action="http://localhost:3300/home" >
    <input type="text" placeholder="Username" name="username" required>
    <input type="number" placeholder="Age" name="age" required>
    <input type="text" placeholder="Field of Work" name="field_of_work" required>
    <input type="text" placeholder="Qualification" name="qualification" required>
    <input type="text" id="profile_image" name="profile_image" placeholder="Image Url">    
    <textarea placeholder="Brief Description" name="brief_description" rows="3" required></textarea>

    <button type="submit">Submit</button>
  </form>
</div>

</body>
</html>