<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Api</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1 class="heads" >Quora Api Trial</h1>
    <% for(post of posts){ %>
    <div class="card">
        <h3 class="handle">@<%= post.username %></h3>
        <p class="data" >-- <%= post.content %></p>
    </div>
    <%}%>
</body>
</html>