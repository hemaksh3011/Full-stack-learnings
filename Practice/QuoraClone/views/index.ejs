<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Api</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1 class="heads" >Quora Api Trial</h1>
    <a href="http://localhost:3300/post/new">Create New Post</a>
    <% for(post of posts){ %>
    <div class="card">
        <h3 class="handle">@<%= post.username %></h3>
        <p class="data" >-- <%= post.content %></p>
        <a href="http://localhost:3300/post/<%= post.id %>">See Deatiled</a>
        <a href="http://localhost:3300/post/<%= post.id %>/edit">Edit post</a> <br> <br>
            <form method="post" action="http://localhost:3300/post/<%= post.id %>?_method=DELETE">
                <button>DELETE</button>
            </form>
    </div>
    <%}%>
</body>
</html>