<% layout("/layouts/boilerplate") %>

<body>

    <div class="container mt-5">
    
        <h2 class="mb-4 text-center">
            "<%= lists.title %>"
        </h2>
    
        <div class=" shadow-sm border-0">
            <div class="row g-0">
    
                <!-- Image Section -->
                <div class="col-md-6">
                    <img 
                        src="<%= lists.image.url %>" 
                        class="img-fluid rounded-start h-100 w-100"
                        style="object-fit: cover;"
                        alt="<%= lists.title %>">
                </div>
    
    
                <!-- Details Section -->
                <div class="col-md-6">
                    <div class="card-body p-4">
    
                        <h4 class="card-title mb-4">
                            <%= lists.title %>
                        </h4>
    
                        <p class="card-text">
                            <strong>Description:</strong><br>
                            <%= lists.description %>
                        </p>
    
                        <hr>
    
                        <p>
                            <strong>Price:</strong>
                            &#8377;<%= lists.price.toLocaleString("en-IN") %>
                        </p>
    
                        <p>
                            <strong>Location:</strong>
                            <%= lists.location %>
                        </p>
    
                        <p>
                            <strong>Country:</strong>
                            <%= lists.country %>
                        </p>
    
                        <p class="text-muted small">
                            <strong>ID:</strong>
                            <%= lists._id %>
                        </p>
    
    
                        <!-- Actions -->
                        <div class="d-flex gap-3 mt-4">
    
                            <a href="/listing/<%= lists._id %>/edit" 
                               class="btn btn-dark">
                                Edit
                            </a>
    
                            <a href="/listing/" 
                               class="btn btn-outline-secondary">
                                Back
                            </a>
    
                            <form action="/listing/<%= lists._id %>?_method=DELETE" method="POST">
                                <button 
                                    type="submit" 
                                    class="btn btn-danger">
                                    Delete
                                </button>
                            </form>
    
                        </div>
    
                    </div>
                </div>
    
            </div>
        </div>
    
    </div>
    
    </body>
