<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f4f4f4;
            padding: 40px;
            display: flex;
            justify-content: center;
        }

        form {
            background: #fff;
            padding: 25px;
            width: 400px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        label {
            font-weight: bold;
            display: block;
            margin-top: 10px;
        }

        input,
        textarea {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }

        button {
            width: 100%;
            margin-top: 15px;
            padding: 10px;
            background: rgb(84, 84, 253);
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <form action="/" method="POST">
        <h2>Create New Listing</h2>

        <label>Title</label><br>
        <input type="text" name="newlist[title]"><br><br>

        <label>Description</label><br>
        <textarea name="newlist[description]" rows="4" cols="40"></textarea><br><br>

        <label>Image URL</label><br>
        <input type="text" name="newlist[imageurl]"><br><br>

        <label>Price</label><br>
        <input type="number" name="newlist[price]"><br><br>

        <label>Location</label><br>
        <input type="text" name="newlist[location]"><br><br>

        <label>Country</label><br>
        <input type="text" name="newlist[country]"><br><br>

        <button type="submit">Add Listing</button>

    </form>
</body>

</html>