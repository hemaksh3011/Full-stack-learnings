<% layout("/layouts/boilerplate") %>

<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class=" shadow-sm border-0">
                    <div class="card-body p-4">

                        <h2 class="mb-4 text-center">Edit Your Listing</h2>

                        <form action="/<%= edit._id %>/?_method=PUT" method="POST">

                            <div class="mb-3">
                                <label class="form-label">Title</label>
                                <input type="text" class="form-control" name="edit[title]" value="<%= edit.title %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="edit[description]"
                                    rows="4"><%= edit.description %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Image URL</label>
                                <input type="text" class="form-control" name="edit[image.url]"
                                    value="<%= edit.image.url %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Price</label>
                                <input type="number" class="form-control" name="edit[price]" value="<%= edit.price %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Location</label>
                                <input type="text" class="form-control" name="edit[location]"
                                    value="<%= edit.location %>">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Country</label>
                                <input type="text" class="form-control" name="edit[country]"
                                    value="<%= edit.country %>">
                            </div>

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-dark flex-grow-1">
                                    Update Listing
                                </button>

                                <a href="/" class="btn btn-outline-secondary">
                                    Back
                                </a>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

</body>