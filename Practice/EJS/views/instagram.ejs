<%- include("includes/head.ejs") %>
<!-- ye hai include wala scene jo ki views me hi banega or default usme se hi jo universal code hoga yani koi specific template usko rakhega like headers and footers -->
<body>
    <h2>The Instagram page of <%= data.name %>
    </h2>
    <button>Follow</button>
    <button>Messege</button>

    <p> Followers : <%= data.followers %> &nbsp;&nbsp;&nbsp;&nbsp; Following : <%= data.following %>
    </p>
    <h4>Here are some posts</h4>

    <p>
        <% for(let post of data.posts){ %>
            <img src="<%= post.image%>" height="150px" alt="">
            <p>Likes : <%= post.likes %> Comments: <%= post.comments %></p>
        <% } %>
    </p>

    <button class="dogs">dogs</button>

</body>
<script src="/index.js" ></script>

</html>