<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDIT</title>
</head>
<body>
    <h2>Haa bhai edit krlo yaha <%= user.emp_mail %> ka name</h2>
    <form method="post" action="/users/<%= user.emp_id %>?_method=PATCH">
