<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Employee</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="page page-add">

    <div class="container center">
        <div class="card form-card">

            <h2 class="heading">Add New Employee</h2>

            <form action="http://localhost:3300/users" method="post" class="form">

                <input class="input" type="text" name="emp_name" placeholder="Employee Name" required>

                <input class="input" type="email" name="emp_mail" placeholder="Employee Email" required>

                <input class="input" type="password" name="emp_pass" placeholder="Password" required>

                <button class="btn btn-primary" type="submit">Add Employee</button>

            </form>

        </div>
    </div>

</body>
</html>