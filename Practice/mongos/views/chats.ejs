<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Chats</title>
</head>
<body>
    <h2>All Chats</h2> 
    <form action="/chat/new" method="get">
        <button type="submit">Add New</button>
    </form> <br>
    <% for(let chat of chats){ %>
        <div class="chat">From :<%= chat.from %></div>
        <div class="chat">-- <%= chat.msg %></div>
        <div class="chat">To :<%= chat.to %></div>
        <div class="chat"><%= chat.date %></div><br><hr>
    <% } %>
</body>
</html>